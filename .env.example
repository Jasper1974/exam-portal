# 本地 SQLite（无需 Docker）
DATABASE_URL="file:./dev.db"

# 生产（Vercel + Neon/Supabase）请改为 postgresql 并填写连接串，例如：
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# 大模型（服务端调用，学生端不直连）
LLM_PROVIDER="auto"
# auto = 优先智谱（国内），无 key 时用 Claude

ZHIPU_API_KEY=""
ANTHROPIC_API_KEY=""

# 管理后台简单口令（查看成绩、导出）
ADMIN_SECRET="change-me-before-deploy"

# 站点地址（部署后改成 Vercel 域名）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
